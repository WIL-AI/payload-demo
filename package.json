{
  "name": "payload-demo",
  "version": "1.0.0",
  "description": "Payload CMS Demo with MongoDB",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.84.0",
    "@payloadcms/next": "^3.84.0",
    "@payloadcms/richtext-lexical": "^3.84.0",
    "@payloadcms/ui": "^3.84.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.2",
    "next": "16.2.6",
    "payload": "^3.84.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.20.2"
  }
}
