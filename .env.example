# MongoDB connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/payload-demo

# Generate a strong random string: openssl rand -base64 32
PAYLOAD_SECRET=your-secret-key-min-32-chars

# Your production URL (for Vercel)
NEXT_PUBLIC_SERVER_URL=https://your-project.vercel.app
